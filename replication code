								recast(scatter) ///
								ciopts(recast(rarea) fcolor(blue%20 reddish%20) fintensity(20) lwidth(none)) ///
								ytitle("") ///						
								ylabel(.05(.05).2) ///
								xtitle("") ///
								xlabel(, angle(45)) ///
								title("Men") ///
								plotopts(msize(large)) ///				
								legend(order(4 "Low Income (T1)" 5 "Medium Income (T2)" 6 "High Income (T3)") title("Income Tertile", size(small)) position(6) col(3) region(lcolor(black)))
									graph save "NAIVE_LOGIT_MEN_INT_YEAR_PR_Q3.gph", replace
									graph export "NAIVE_LOGIT_MEN_INT_YEAR_PR_Q3.png", replace
						
						margins, dydx(2.l2q3rincome0_as 3.l2q3rincome0_as) at(year_group3=(1 2 3)) post coefleg			
								marginsplot, ///
									recast(scatter) ///
									ciopts(recast(rarea) fcolor(blue%20 reddish%20) fintensity(20) lwidth(none)) ///
									ytitle("") ///
									yscale(range(0 .07)) ///
									ylabel(0(.02).07) ///
									xtitle("") ///
									xlabel(, angle(45)) ///
									yline(0, lcolor(reddish) lpattern(dash)) ///
									title("Men") ///
									plotopts(msize(large)) ///
									legend(order(3 "Tertile 2 vs. 1" 4 "Tertile 3 vs. 1") ///
										position(6) col(2) region(lcolor(black)))					
									graph save "NAIVE_LOGIT_MEN_INT_YEAR_AME_Q3.gph", replace
									graph export "NAIVE_LOGIT_MEN_INT_YEAR_AME_Q3.png", replace

									grc1leg "NAIVE_LOGIT_MEN_INT_YEAR_AME_Q3.gph" "NAIVE_LOGIT_WOMEN_INT_YEAR_AME_Q3.gph", title("Married Couples", size(medium))
										graph save "NAIVE_LOGIT_MEN_WOMEN_INT_YEAR_AME_Q3.gph", replace
