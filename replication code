									graph save "NAIVE_LOGIT_WOMEN_INT_YEAR_AME_Q3.gph", replace
									graph export "NAIVE_LOGIT_WOMEN_INT_YEAR_AME_Q3.png", replace
										
				*Men
				logistic child1_tv2 b1.l2q3rincome0_as##b1.year_group3 b1.l2q3rincome_partner0_as##b1.year_group3 i.h_l_nasc_c_head i.h_l_nasc_c_partner partner_timing0 ///
					h_partnership_age_men h_partnership_age_women i.l2modello_ i.l2modello_partner if sesso_id_des==2
					
					margins i.l2q3rincome0_as, at(year_group3=(0 1 2 3))
