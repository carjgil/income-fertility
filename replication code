	*Figure 2. Model 2A: AMEs of individual medium and top income tertiles (vs 0=bottom 1st tertile) on the transition to first child by sex and over year periods among married couples and single/cohabitors
		
		*MARRIED
			use "married.dta", clear

				*Women
				logistic child1_tv2 b1.l2q3rincome0_as##b1.year_group3 b1.l2q3rincome_partner0_as##b1.year_group3 i.h_l_nasc_c_head i.h_l_nasc_c_partner partner_timing0 ///
					h_partnership_age_men h_partnership_age_women i.l2modello_ i.l2modello_partner if sesso_id_des==1
					
					margins i.l2q3rincome0_as, at(year_group3=(0 1 2 3))
						marginsplot, ///
								recast(scatter) ///
								ciopts(recast(rarea) fcolor(blue%20 reddish%20) fintensity(20) lwidth(none)) ///
								ytitle("") ///						
								ylabel(.05(.05).2) ///
								xtitle("") ///
								xlabel(, angle(45)) ///
								title("Women") ///
								plotopts(msize(large)) ///				
								legend(order(4 "Low Income (T1)" 5 "Medium Income (T2)" 6 "High Income (T3)") title("Income Tertile", size(small)) position(6) col(3) region(lcolor(black)))
									graph save "NAIVE_LOGIT_WOMEN_INT_YEAR_PR_Q3.gph", replace
									graph export "NAIVE_LOGIT_WOMEN_INT_YEAR_PR_Q3.png", replace

						margins, dydx(2.l2q3rincome0_as 3.l2q3rincome0_as) at(year_group3=(1 2 3)) post coefleg			
								marginsplot, ///
									recast(scatter) ///
									ciopts(recast(rarea) fcolor(blue%20 reddish%20) fintensity(20) lwidth(none)) ///
									ytitle("") ///
									yscale(range(0 .07)) ///
									ylabel(0(.02).07) ///
									xtitle("") ///
									xlabel(, angle(45)) ///
									yline(0, lcolor(reddish) lpattern(dash)) ///
									title("Women") ///
									plotopts(msize(large)) ///
									legend(order(3 "Tertile 2 vs. 1" 4 "Tertile 3 vs. 1") ///
